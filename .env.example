# ============================================================================
#  Assistant vocal — configuration (copie ce fichier en .env et remplis-le)
#  cp .env.example .env
#  Rien ici ne quitte ta machine. .env est gitignore.
# ============================================================================

# --- Identite (renommage de l'assistante) ----------------------------------
# Le nom que tu donnes a ton assistante. Elle repond quand ta phrase commence
# par ce nom. Change-le librement (ex: Jarvis, Sora, Friday...).
ASSISTANT_NAME=Moleck
# Ton nom / le proprietaire a qui elle parle.
OWNER_NAME=

# --- Cerveau (LLM) — A BRANCHER SUR TON PROPRE SETUP ------------------------
# L'assistante parle a un endpoint compatible OpenAI (LiteLLM, Ollama, vLLM,
# OpenAI, Together, etc.). Mets TON URL et TA cle.
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=
# Modele principal et repli (noms tels que ton gateway les expose).
MODEL_PRIMARY=
MODEL_FALLBACK=
# Modele vision (optionnel) pour l'analyse d'images, expose par ton gateway.
MODEL_VISION=
# Cerveau par defaut : litellm (endpoint ci-dessus) ou claude (CLI Claude Code).
BRAIN=litellm
# Optionnel : escalade vers Claude Code en CLI.
CLAUDE_BIN=claude
CLAUDE_MODEL=

# --- Reconnaissance vocale (STT) -------------------------------------------
WHISPER_MODEL=base
LANGUAGE=fr
# Index du micro d'entree (laisser vide = micro par defaut systeme).
STT_INPUT_DEVICE=
# Seuil du verrou locuteur (0..1). Apres enrollment via enroll_speaker.py.
SPEAKER_THRESHOLD=0.72

# --- Synthese vocale (TTS) --------------------------------------------------
# Moteur principal : cloud ou local.
TTS_PRIMARY=local
TTS_VOICE_CLOUD=
TTS_VOICE_LOCAL=

# --- Code secret (optionnel) -----------------------------------------------
# Phrase secrete PARLEE exigee pour deverrouiller l'acces complet (mode cockpit)
# depuis le mode maison, et pour toute action marquee sensible. A CHANGER.
PROD_PASSPHRASE=

# --- API mobile / PWA (optionnel, reseau prive uniquement) -----------------
DALIA_API_TOKEN=
DALIA_API_PORT=8765

# --- Integrations optionnelles (laisser vide si non utilisees) -------------
YOUTUBE_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
